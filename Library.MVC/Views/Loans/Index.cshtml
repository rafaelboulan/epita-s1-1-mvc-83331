@model IEnumerable<Library.Domain.Loan>

@{
    ViewData["Title"] = "Loans";
}

<h1>Loans Management</h1>

<a asp-action="Create" class="btn btn-success mb-3">Create New Loan</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Member</th>
            <th>Book</th>
            <th>Loan Date</th>
            <th>Due Date</th>
            <th>Returned Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Member.FullName</td>
                <td>@item.Book.Title</td>
                <td>@item.LoanDate.ToShortDateString()</td>
                <td>@item.DueDate.ToShortDateString()</td>
                <td>@(item.ReturnedDate?.ToShortDateString() ?? "-")</td>
                <td>
                    @if (item.ReturnedDate != null)
                    {
                        <span class="badge bg-success">Returned</span>
                    }
                    else if (item.IsOverdue)
                    {
                        <span class="badge bg-danger">Overdue</span>
                    }
                    else
                    {
                        <span class="badge bg-info">Active</span>
                    }
                </td>
                <td>
                    @if (item.ReturnedDate == null)
                    {
                        <a asp-action="MarkReturned" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Mark Returned</a>
                    }
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
